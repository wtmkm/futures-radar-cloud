[Unit]
Description=Futures Intraday Analysis Web App
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/futures-intraday
Environment=HOST=127.0.0.1
Environment=PORT=8765
ExecStart=/usr/bin/python3 /opt/futures-intraday/app.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
